#!/usr/bin/env python3
"""
Label Propagation vs Random Forest Classifier Comparison
=========================================================

Compares semi-supervised learning approaches for INTENT CLASSIFICATION:

⚠️ IMPORTANT: This is INTENT CLASSIFICATION, not error detection!
Task: Classify manipulated features as intentional (1) vs unintentional (-1)

APPROACH 1: Graph-Based Label Propagation
  1. Load clean + manipulated records with intent labels (-1, 0, 1)
  2. Extract only manipulated features (intent != 0)
  3. Cluster variants using aggregate features (NO intent labels)
  4. Sample representatives (~1%) from clusters
  5. Build similarity graph (k-NN) on feature-level data
  6. Propagate labels using sklearn's LabelPropagation & LabelSpreading
  7. Evaluate on unseen manipulated features

APPROACH 2: Cluster-Constrained Propagation
  1. Same data loading and clustering
  2. Within each cluster, propagate majority label from representatives
  3. Evaluate on unseen manipulated features

APPROACH 3: Random Forest Classifier (Baseline - YOUR PIPELINE)
  1. Same clustering and sampling as your successful pipeline
  2. Train RF classifier on sampled features
  3. Evaluate on unseen manipulated features
  4. Baseline: HDBSCAN achieved 91.87% F1 (91.53% intentional, 92.17% unintentional)

Key Features:
- Intent classification: intentional (1) vs unintentional (-1) 
- Only processes manipulated features (excludes correct features with intent=0)
- NO DATA LEAKAGE: Intent labels only used for evaluation
- Matches your successful clustering pipeline architecture
- Detailed logging and visualization
"""

import matplotlib
matplotlib.use('Agg')

import pandas as pd
import numpy as np
import matplotlib.pyplot as plt
import seaborn as sns
from sklearn.ensemble import RandomForestClassifier
from sklearn.preprocessing import StandardScaler, LabelEncoder
from sklearn.metrics import (
    accuracy_score, classification_report, confusion_matrix,
    f1_score, precision_score, recall_score
)
from sklearn.cluster import KMeans, DBSCAN, AgglomerativeClustering
from sklearn.mixture import GaussianMixture
from sklearn.semi_supervised import LabelPropagation, LabelSpreading
from sklearn.neighbors import kneighbors_graph
import warnings
from pathlib import Path
from tqdm import tqdm
from collections import defaultdict
import time
from datetime import datetime
import json

warnings.filterwarnings('ignore')

# Try to import HDBSCAN
try:
    import hdbscan
    HDBSCAN_AVAILABLE = True
except ImportError:
    HDBSCAN_AVAILABLE = False
    print("⚠️  HDBSCAN not available. Install with: pip install hdbscan")


class LabelPropagationComparison:
    """Compare label propagation methods against Random Forest classifier"""
    
    def __init__(self, target_samples=None, random_state=42,
                 mask_path=None, clean_path=None, dirty_path=None):
        """
        Initialize comparison framework.
        
        Args:
            target_samples: Number of variants to sample (~1%). If None, auto-calculated.
            random_state: Random seed for reproducibility
            mask_path: Path to masks.csv (intent labels: -1, 0, 1)
            clean_path: Path to correct_records.csv
            dirty_path: Path to manipulated_records.csv
        """
        self.target_samples = target_samples
        self.random_state = random_state
        np.random.seed(random_state)
        
        # Setup paths - use tenth-trial data by default (matches your 91.87% baseline)
        if mask_path and clean_path and dirty_path:
            self.mask_path = Path(mask_path)
            self.clean_path = Path(clean_path)
            self.dirty_path = Path(dirty_path)
        else:
            # Auto-detect from script location
            script_dir = Path(__file__).parent.resolve()  # scripts/
            clustering_dir = script_dir.parent  # clustering-organized/
            attribution_dir = clustering_dir.parent  # attribution/
            src_dir = attribution_dir.parent  # src/
            error_detection_dir = src_dir.parent  # error_detection_system/
            llms_baseline_dir = error_detection_dir.parent  # llms_baseline/
            
            # Use tenth-trial dataset (same as your 91.87% F1 result)
            dataset_dir = llms_baseline_dir / 'adult_income_dataset' / 'tenth-trial' / 'data' / 'raw'
            self.mask_path = dataset_dir / 'run_20251031_211812' / 'masks.csv'
            self.clean_path = dataset_dir / 'correct_records.csv'
            self.dirty_path = dataset_dir / 'run_20251031_211812' / 'manipulated_records.csv'
        
        # Create timestamped output folders
        self.timestamp = datetime.now().strftime("%Y%m%d_%H%M%S")
        script_dir = Path(__file__).parent.resolve()
        parent_dir = script_dir.parent
        self.run_dir = parent_dir / 'outputs' / f'run_label_prop_{self.timestamp}'
        self.results_dir = self.run_dir / 'results'
        self.plots_dir = self.run_dir / 'plots'
        self.logs_dir = self.run_dir / 'logs'
        
        # Create directories
        self.results_dir.mkdir(parents=True, exist_ok=True)
        self.plots_dir.mkdir(parents=True, exist_ok=True)
        self.logs_dir.mkdir(parents=True, exist_ok=True)
        
        # Storage
        self.all_results = []
        
        print(f"\n{'='*70}")
        print("LABEL PROPAGATION VS RANDOM FOREST COMPARISON")
        print(f"{'='*70}")
        print(f"Output directory: {self.run_dir}")
        print(f"Random state: {random_state}")
        
    def load_data(self):
        """
        Load data matching the successful clustering pipeline.
        Loads clean records, manipulated records, and intent masks.
        Extracts ONLY manipulated features (intent != 0) for classification.
        """
        print(f"\n{'='*70}")
        print("LOADING DATA (INTENT CLASSIFICATION)")
        print(f"{'='*70}")
        
        if not self.mask_path.exists():
            raise FileNotFoundError(f"Mask file not found: {self.mask_path}")
        if not self.clean_path.exists():
            raise FileNotFoundError(f"Clean file not found: {self.clean_path}")
        if not self.dirty_path.exists():
            raise FileNotFoundError(f"Dirty file not found: {self.dirty_path}")
        
        print(f"Mask: {self.mask_path}")
        print(f"Clean: {self.clean_path}")
        print(f"Dirty: {self.dirty_path}")
        
        # Load data
        mask_df = pd.read_csv(self.mask_path)
        manipulated_df = pd.read_csv(self.dirty_path)
        correct_df = pd.read_csv(self.clean_path)
        
        print(f"✓ Loaded masks: {mask_df.shape}")
        print(f"✓ Loaded manipulated records: {manipulated_df.shape}")
        print(f"✓ Loaded correct records: {correct_df.shape}")
        
        if mask_df.shape != manipulated_df.shape:
            raise ValueError(f"Shape mismatch: mask {mask_df.shape} vs manipulated {manipulated_df.shape}")
        
        print(f"\nProcessing {len(mask_df)} variant records into feature changes...")
        
        # Get feature columns (exclude ID if present)
        feature_cols = [col for col in mask_df.columns if col.lower() not in ['id', 'variant_id', 'record_id']]
        print(f"Features to process: {len(feature_cols)}")
        
        # Extract manipulated features with intent labels
        all_features = []
        
        for variant_idx in tqdm(range(len(mask_df)), desc="Processing variants", unit="variant"):
            variant_clean = correct_df.iloc[variant_idx] if variant_idx < len(correct_df) else None
            variant_dirty = manipulated_df.iloc[variant_idx]
            variant_mask = mask_df.iloc[variant_idx]
            
            for feature_col in feature_cols:
                intent_label = int(variant_mask[feature_col])
                
                # Only process manipulated features (intent != 0)
                if intent_label != 0:
                    clean_value = variant_clean[feature_col] if variant_clean is not None else None
                    dirty_value = variant_dirty[feature_col]
                    
                    all_features.append({
                        'variant_id': variant_idx,
                        'feature_name': feature_col,
                        'clean_value': clean_value,
                        'dirty_value': dirty_value,
                        'intent_label': intent_label  # 1=intentional, -1=unintentional
                    })
        
        self.df = pd.DataFrame(all_features)
        
        print(f"\n✓ Created dataset with {len(self.df)} manipulated features")
        print(f"  Intentional (1): {(self.df['intent_label'] == 1).sum()}")
        print(f"  Unintentional (-1): {(self.df['intent_label'] == -1).sum()}")
        print(f"  Unique variants: {self.df['variant_id'].nunique()}")
        
        # Encode features for ML
        print("\nEncoding features...")
        self.df['feature_name_encoded'] = LabelEncoder().fit_transform(self.df['feature_name'].astype(str))
        
        # Encode clean and dirty values
        le_clean = LabelEncoder()
        le_dirty = LabelEncoder()
        self.df['clean_value_encoded'] = le_clean.fit_transform(self.df['clean_value'].astype(str).fillna('MISSING'))
        self.df['dirty_value_encoded'] = le_dirty.fit_transform(self.df['dirty_value'].astype(str))
        
        # Convert to numeric where possible
        self.df['clean_value_numeric'] = pd.to_numeric(self.df['clean_value'], errors='coerce').fillna(0)
        self.df['dirty_value_numeric'] = pd.to_numeric(self.df['dirty_value'], errors='coerce').fillna(0)
        
        # Add derived features
        self.df['value_change'] = self.df['dirty_value_numeric'] - self.df['clean_value_numeric']
        self.df['value_change_abs'] = np.abs(self.df['value_change'])
        self.df['value_change_log'] = np.log1p(np.abs(self.df['value_change']))
        
        # Store dataset info
        self.total_variants = self.df['variant_id'].nunique()
        self.total_features = len(self.df)
        
        # Set target_samples to 1% of variants if not specified
        if self.target_samples is None:
            self.target_samples = max(1, int(self.total_variants * 0.01))
            print(f"\n⚙️  Auto-calculated target_samples: {self.target_samples} (1% of {self.total_variants} variants)")
        
        print(f"\nDataset summary:")
        print(f"  Total variants: {self.total_variants}")
        print(f"  Total manipulated features: {self.total_features}")
        print(f"  Target samples for training: {self.target_samples} variants ({self.target_samples/self.total_variants*100:.2f}%)")
        print(f"  Intentional: {(self.df['intent_label'] == 1).sum()} ({(self.df['intent_label'] == 1).mean()*100:.2f}%)")
        print(f"  Unintentional: {(self.df['intent_label'] == -1).sum()} ({(self.df['intent_label'] == -1).mean()*100:.2f}%)")
        print(f"\n⚠️  Baseline to beat: HDBSCAN + RF = 91.87% F1 (91.53% intentional, 92.17% unintentional)")
        
    def create_aggregate_features(self):
        """
        Create aggregate features per record for clustering.
        NO error labels used (avoid data leakage).
        """
        print(f"\n{'='*70}")
        print("CREATING AGGREGATE FEATURES PER RECORD")
        print(f"{'='*70}")
        
        aggregated = []
        
        for record_id in tqdm(self.df['record_id'].unique(), desc="Aggregating features", unit="record"):
            record_data = self.df[self.df['record_id'] == record_id]
            
            # Count features (NO error labels)
            n_cells = len(record_data)
            
            # Value statistics
            mean_value_encoded = record_data['cell_value_encoded'].mean()
            std_value_encoded = record_data['cell_value_encoded'].std() if len(record_data) > 1 else 0
            min_value_encoded = record_data['cell_value_encoded'].min()
            max_value_encoded = record_data['cell_value_encoded'].max()
            
            # Numeric value statistics
            mean_value_numeric = record_data['cell_value_numeric'].mean()
            std_value_numeric = record_data['cell_value_numeric'].std() if len(record_data) > 1 else 0
            min_value_numeric = record_data['cell_value_numeric'].min()
            max_value_numeric = record_data['cell_value_numeric'].max()
            
            # Feature diversity
            n_unique_features = record_data['feature_name'].nunique()
            
            features = {
                'record_id': record_id,
                'n_cells': n_cells,
                'mean_value_encoded': mean_value_encoded,
                'std_value_encoded': std_value_encoded,
                'min_value_encoded': min_value_encoded,
                'max_value_encoded': max_value_encoded,
                'mean_value_numeric': mean_value_numeric,
                'std_value_numeric': std_value_numeric,
                'min_value_numeric': min_value_numeric,
                'max_value_numeric': max_value_numeric,
                'n_unique_features': n_unique_features,
            }
            
            aggregated.append(features)
        
        agg_df = pd.DataFrame(aggregated).fillna(0)
        
        print(f"\n✓ Created {len(agg_df)} aggregate feature vectors")
        print(f"  Feature dimension: {len(agg_df.columns) - 1}")
        
        return agg_df
    
    def cluster_kmeans(self, features, n_clusters=15):
        """K-Means clustering"""
        print(f"\n{'='*70}")
        print("K-MEANS CLUSTERING")
        print(f"{'='*70}")
        
        start_time = time.time()
        kmeans = KMeans(n_clusters=n_clusters, random_state=self.random_state, n_init=10)
        labels = kmeans.fit_predict(features)
        runtime = time.time() - start_time
        
        n_clusters_found = len(np.unique(labels))
        print(f"✓ K-Means completed in {runtime:.2f}s")
        print(f"  Clusters: {n_clusters_found}")
        
        return labels, {
            'algorithm': 'K-Means',
            'n_clusters': n_clusters_found,
            'runtime': runtime,
        }
    
    def cluster_dbscan(self, features, eps=None, min_samples=5):
        """DBSCAN clustering"""
        print(f"\n{'='*70}")
        print("DBSCAN CLUSTERING")
        print(f"{'='*70}")
        
        start_time = time.time()
        
        if eps is None:
            from sklearn.neighbors import NearestNeighbors
            neighbors = NearestNeighbors(n_neighbors=min_samples)
            neighbors_fit = neighbors.fit(features)
            distances, _ = neighbors_fit.kneighbors(features)
            distances = np.sort(distances[:, -1])
            eps = np.percentile(distances, 90)
            
            if eps <= 0 or np.isnan(eps):
                eps = max(0.5, np.mean(distances[distances > 0]) if np.any(distances > 0) else 0.5)
                print(f"  ⚠️  Using fallback eps: {eps:.4f}")
            else:
                print(f"  Auto-tuned eps: {eps:.4f}")
        
        dbscan = DBSCAN(eps=eps, min_samples=min_samples)
        labels = dbscan.fit_predict(features)
        runtime = time.time() - start_time
        
        n_clusters = len(set(labels)) - (1 if -1 in labels else 0)
        n_noise = list(labels).count(-1)
        
        print(f"✓ DBSCAN completed in {runtime:.2f}s")
        print(f"  Clusters: {n_clusters}")
        print(f"  Noise points: {n_noise} ({100*n_noise/len(labels):.1f}%)")
        
        return labels, {
            'algorithm': 'DBSCAN',
            'n_clusters': n_clusters,
            'n_noise': n_noise,
            'runtime': runtime,
        }
    
    def proportional_sampling(self, agg_df, labels):
        """
        Proportional sampling from clusters (NO DATA LEAKAGE).
        Returns selected record IDs.
        """
        print(f"\n{'='*70}")
        print("PROPORTIONAL SAMPLING FROM CLUSTERS")
        print(f"{'='*70}")
        
        # Handle noise points
        valid_mask = labels != -1
        valid_indices = np.where(valid_mask)[0]
        valid_labels = labels[valid_mask]
        
        if len(valid_indices) == 0:
            print("⚠️  No valid clusters found!")
            return []
        
        valid_record_ids = agg_df.iloc[valid_indices]['record_id'].values
        
        # Count records per cluster
        unique_labels = np.unique(valid_labels)
        cluster_sizes = {label: (valid_labels == label).sum() for label in unique_labels}
        
        print(f"Clusters: {len(unique_labels)}")
        print(f"Valid records: {len(valid_indices)}")
        
        # Proportional allocation
        total_valid = len(valid_indices)
        allocation = {}
        
        for label in unique_labels:
            base_allocation = (cluster_sizes[label] / total_valid) * self.target_samples
            allocation[label] = max(1, int(round(base_allocation)))
        
        # Adjust to match target
        total_allocated = sum(allocation.values())
        while total_allocated > self.target_samples and any(v > 1 for v in allocation.values()):
            largest = max(allocation.items(), key=lambda x: x[1])[0]
            if allocation[largest] > 1:
                allocation[largest] -= 1
                total_allocated -= 1
        
        while total_allocated < self.target_samples:
            largest = max(cluster_sizes.items(), key=lambda x: x[1])[0]
            allocation[largest] += 1
            total_allocated += 1
        
        # Sample from each cluster
        selected_record_ids = []
        
        for label in unique_labels:
            n_samples = allocation[label]
            cluster_mask = valid_labels == label
            cluster_record_ids = valid_record_ids[cluster_mask]
            
            if len(cluster_record_ids) >= n_samples:
                sampled = np.random.choice(cluster_record_ids, size=n_samples, replace=False)
            else:
                sampled = cluster_record_ids
            
            selected_record_ids.extend(sampled)
        
        print(f"\n✓ Selected {len(selected_record_ids)} records from {len(unique_labels)} clusters")
        
        # Get cells from selected records
        train_cells = self.df[self.df['record_id'].isin(selected_record_ids)]
        print(f"  Total cells: {len(train_cells)}")
        print(f"  Errors: {(train_cells['error_label'] == 1).sum()}")
        print(f"  Correct: {(train_cells['error_label'] == 0).sum()}")
        
        return selected_record_ids
    
    def approach1_graph_label_propagation(self, algorithm_name, selected_record_ids, labels):
        """
        Approach 1: Graph-Based Label Propagation using sklearn
        """
        print(f"\n{'='*70}")
        print(f"APPROACH 1: GRAPH-BASED LABEL PROPAGATION - {algorithm_name}")
        print(f"{'='*70}")
        
        # Prepare features for all cells
        feature_cols = ['feature_name_encoded', 'cell_value_encoded', 
                       'value_log', 'value_magnitude']
        X = self.df[feature_cols].values
        
        # Create label array: -1 for unlabeled, 0 for correct, 1 for error
        y = np.full(len(self.df), -1, dtype=int)
        
        # Set labels for cells from selected records
        selected_mask = self.df['record_id'].isin(selected_record_ids)
        y[selected_mask] = self.df.loc[selected_mask, 'error_label'].values
        
        n_labeled = (y != -1).sum()
        n_unlabeled = (y == -1).sum()
        
        print(f"\nPreparing graph-based propagation:")
        print(f"  Total cells: {len(y)}")
        print(f"  Labeled cells: {n_labeled} ({n_labeled/len(y)*100:.2f}%)")
        print(f"  Unlabeled cells: {n_unlabeled} ({n_unlabeled/len(y)*100:.2f}%)")
        print(f"  Labeled errors: {(y == 1).sum()}")
        print(f"  Labeled correct: {(y == 0).sum()}")
        
        # Scale features
        scaler = StandardScaler()
        X_scaled = scaler.fit_transform(X)
        
        results = {}
        
        # Method 1: LabelPropagation (hard labels)
        print(f"\n--- Method 1: LabelPropagation (hard labels) ---")
        start_time = time.time()
        
        lp = LabelPropagation(kernel='knn', n_neighbors=7, max_iter=1000)
        lp.fit(X_scaled, y)
        y_pred_lp = lp.predict(X_scaled)
        runtime_lp = time.time() - start_time
        
        # Evaluate only on truly unlabeled cells
        test_mask = y == -1
        y_true_test = self.df.loc[test_mask, 'error_label'].values
        y_pred_test_lp = y_pred_lp[test_mask]
        
        acc_lp = accuracy_score(y_true_test, y_pred_test_lp)
        f1_lp = f1_score(y_true_test, y_pred_test_lp, average='weighted', zero_division=0)
        f1_error_lp = f1_score(y_true_test, y_pred_test_lp, pos_label=1, zero_division=0)
        f1_correct_lp = f1_score(y_true_test, y_pred_test_lp, pos_label=0, zero_division=0)
        
        print(f"✓ LabelPropagation completed in {runtime_lp:.2f}s")
        print(f"  Accuracy: {acc_lp:.4f}")
        print(f"  F1 Weighted: {f1_lp:.4f}")
        print(f"  F1 Error: {f1_error_lp:.4f}")
        print(f"  F1 Correct: {f1_correct_lp:.4f}")
        
        results['LabelPropagation'] = {
            'method': 'LabelPropagation',
            'algorithm': algorithm_name,
            'accuracy': acc_lp,
            'f1_weighted': f1_lp,
            'f1_error': f1_error_lp,
            'f1_correct': f1_correct_lp,
            'runtime': runtime_lp,
            'n_labeled': n_labeled,
            'n_test': len(y_true_test),
        }
        
        # Method 2: LabelSpreading (soft labels with clamping)
        print(f"\n--- Method 2: LabelSpreading (soft labels) ---")
        start_time = time.time()
        
        ls = LabelSpreading(kernel='knn', n_neighbors=7, alpha=0.2, max_iter=1000)
        ls.fit(X_scaled, y)
        y_pred_ls = ls.predict(X_scaled)
        runtime_ls = time.time() - start_time
        
        y_pred_test_ls = y_pred_ls[test_mask]
        
        acc_ls = accuracy_score(y_true_test, y_pred_test_ls)
        f1_ls = f1_score(y_true_test, y_pred_test_ls, average='weighted', zero_division=0)
        f1_error_ls = f1_score(y_true_test, y_pred_test_ls, pos_label=1, zero_division=0)
        f1_correct_ls = f1_score(y_true_test, y_pred_test_ls, pos_label=0, zero_division=0)
        
        print(f"✓ LabelSpreading completed in {runtime_ls:.2f}s")
        print(f"  Accuracy: {acc_ls:.4f}")
        print(f"  F1 Weighted: {f1_ls:.4f}")
        print(f"  F1 Error: {f1_error_ls:.4f}")
        print(f"  F1 Correct: {f1_correct_ls:.4f}")
        
        results['LabelSpreading'] = {
            'method': 'LabelSpreading',
            'algorithm': algorithm_name,
            'accuracy': acc_ls,
            'f1_weighted': f1_ls,
            'f1_error': f1_error_ls,
            'f1_correct': f1_correct_ls,
            'runtime': runtime_ls,
            'n_labeled': n_labeled,
            'n_test': len(y_true_test),
        }
        
        return results
    
    def approach2_cluster_constrained_propagation(self, algorithm_name, selected_record_ids, labels, agg_df):
        """
        Approach 2: Cluster-Constrained Propagation
        Propagate majority label within each cluster
        """
        print(f"\n{'='*70}")
        print(f"APPROACH 2: CLUSTER-CONSTRAINED PROPAGATION - {algorithm_name}")
        print(f"{'='*70}")
        
        # Build cluster membership for all records
        record_to_cluster = {}
        for idx, record_id in enumerate(agg_df['record_id'].values):
            cluster_label = labels[idx]
            if cluster_label != -1:  # Skip noise points
                record_to_cluster[record_id] = cluster_label
        
        # Calculate majority label per cluster from labeled records
        cluster_labels = defaultdict(list)
        for record_id in selected_record_ids:
            if record_id in record_to_cluster:
                cluster_id = record_to_cluster[record_id]
                # Get error labels from this record's cells
                record_cells = self.df[self.df['record_id'] == record_id]
                for error_label in record_cells['error_label'].values:
                    cluster_labels[cluster_id].append(error_label)
        
        # Compute majority label per cluster
        cluster_majority = {}
        for cluster_id, labels_list in cluster_labels.items():
            # Majority vote
            n_errors = sum(labels_list)
            n_total = len(labels_list)
            majority_label = 1 if n_errors > n_total / 2 else 0
            cluster_majority[cluster_id] = majority_label
        
        print(f"\nCluster majority labels computed for {len(cluster_majority)} clusters")
        
        # Predict: assign cluster's majority label to all unlabeled cells in that cluster
        y_pred = []
        y_true = []
        test_mask = ~self.df['record_id'].isin(selected_record_ids)
        
        for idx, row in self.df[test_mask].iterrows():
            record_id = row['record_id']
            true_label = row['error_label']
            
            if record_id in record_to_cluster:
                cluster_id = record_to_cluster[record_id]
                pred_label = cluster_majority.get(cluster_id, 0)  # Default to 0 if cluster has no labels
            else:
                # Record in noise cluster, predict most common label
                pred_label = 0
            
            y_pred.append(pred_label)
            y_true.append(true_label)
        
        y_pred = np.array(y_pred)
        y_true = np.array(y_true)
        
        # Calculate metrics
        acc = accuracy_score(y_true, y_pred)
        f1 = f1_score(y_true, y_pred, average='weighted', zero_division=0)
        f1_error = f1_score(y_true, y_pred, pos_label=1, zero_division=0)
        f1_correct = f1_score(y_true, y_pred, pos_label=0, zero_division=0)
        
        print(f"\n✓ Cluster-constrained propagation completed")
        print(f"  Accuracy: {acc:.4f}")
        print(f"  F1 Weighted: {f1:.4f}")
        print(f"  F1 Error: {f1_error:.4f}")
        print(f"  F1 Correct: {f1_correct:.4f}")
        print(f"  Test cells: {len(y_true)}")
        
        return {
            'method': 'ClusterConstrained',
            'algorithm': algorithm_name,
            'accuracy': acc,
            'f1_weighted': f1,
            'f1_error': f1_error,
            'f1_correct': f1_correct,
            'runtime': 0,  # Negligible
            'n_test': len(y_true),
        }
    
    def approach3_random_forest(self, algorithm_name, selected_record_ids):
        """
        Approach 3: Random Forest Classifier (baseline)
        """
        print(f"\n{'='*70}")
        print(f"APPROACH 3: RANDOM FOREST CLASSIFIER - {algorithm_name}")
        print(f"{'='*70}")
        
        # Prepare train/test split
        train_mask = self.df['record_id'].isin(selected_record_ids)
        test_mask = ~train_mask
        
        feature_cols = ['feature_name_encoded', 'cell_value_encoded', 
                       'value_log', 'value_magnitude']
        
        X_train = self.df.loc[train_mask, feature_cols].values
        y_train = self.df.loc[train_mask, 'error_label'].values
        X_test = self.df.loc[test_mask, feature_cols].values
        y_test = self.df.loc[test_mask, 'error_label'].values
        
        print(f"\nTraining data:")
        print(f"  Train cells: {len(X_train)}")
        print(f"  Test cells: {len(X_test)}")
        print(f"  Train errors: {(y_train == 1).sum()}")
        print(f"  Train correct: {(y_train == 0).sum()}")
        
        # Train Random Forest
        start_time = time.time()
        
        rf = RandomForestClassifier(
            n_estimators=200,
            max_depth=15,
            min_samples_split=5,
            class_weight='balanced',
            random_state=self.random_state,
            n_jobs=-1
        )
        rf.fit(X_train, y_train)
        
        y_pred = rf.predict(X_test)
        runtime = time.time() - start_time
        
        # Calculate metrics
        acc = accuracy_score(y_test, y_pred)
        f1 = f1_score(y_test, y_pred, average='weighted', zero_division=0)
        f1_error = f1_score(y_test, y_pred, pos_label=1, zero_division=0)
        f1_correct = f1_score(y_test, y_pred, pos_label=0, zero_division=0)
        
        print(f"\n✓ Random Forest completed in {runtime:.2f}s")
        print(f"  Accuracy: {acc:.4f}")
        print(f"  F1 Weighted: {f1:.4f}")
        print(f"  F1 Error: {f1_error:.4f}")
        print(f"  F1 Correct: {f1_correct:.4f}")
        
        return {
            'method': 'RandomForest',
            'algorithm': algorithm_name,
            'accuracy': acc,
            'f1_weighted': f1,
            'f1_error': f1_error,
            'f1_correct': f1_correct,
            'runtime': runtime,
            'n_test': len(y_test),
        }
    
    def run_comparison(self):
        """Run complete comparison"""
        print(f"\n{'='*70}")
        print("STARTING COMPARISON")
        print(f"{'='*70}")
        
        # Load data
        self.load_data()
        
        # Create aggregate features
        agg_df = self.create_aggregate_features()
        
        # Prepare features for clustering
        feature_cols = [col for col in agg_df.columns if col != 'record_id']
        features = agg_df[feature_cols].values
        
        # Standardize
        scaler = StandardScaler()
        features_scaled = scaler.fit_transform(features)
        
        print(f"\n✓ Prepared features for clustering: {features_scaled.shape}")
        
        # Test clustering algorithms
        algorithms = [
            ('K-Means', lambda: self.cluster_kmeans(features_scaled, n_clusters=15)),
            ('DBSCAN', lambda: self.cluster_dbscan(features_scaled)),
        ]
        
        all_results = []
        
        for algo_name, cluster_func in algorithms:
            print(f"\n{'#'*70}")
            print(f"# TESTING ALGORITHM: {algo_name}")
            print(f"{'#'*70}")
            
            try:
                # Cluster
                labels, cluster_info = cluster_func()
                
                if labels is None or len(np.unique(labels[labels != -1])) < 2:
                    print(f"⚠️  Insufficient clusters for {algo_name}, skipping...")
                    continue
                
                # Sample representatives
                selected_record_ids = self.proportional_sampling(agg_df, labels)
                
                if len(selected_record_ids) == 0:
                    print(f"⚠️  No records selected for {algo_name}, skipping...")
                    continue
                
                # Approach 1: Graph-Based Label Propagation
                results_lp = self.approach1_graph_label_propagation(
                    algo_name, selected_record_ids, labels
                )
                for method_name, result in results_lp.items():
                    all_results.append(result)
                
                # Approach 2: Cluster-Constrained Propagation
                result_cc = self.approach2_cluster_constrained_propagation(
                    algo_name, selected_record_ids, labels, agg_df
                )
                all_results.append(result_cc)
                
                # Approach 3: Random Forest
                result_rf = self.approach3_random_forest(
                    algo_name, selected_record_ids
                )
                all_results.append(result_rf)
                
            except Exception as e:
                print(f"❌ Error with {algo_name}: {e}")
                import traceback
                traceback.print_exc()
                continue
        
        # Save results
        self.all_results = all_results
        self.save_results()
        self.create_visualizations()
        self.print_summary()
        
        print(f"\n{'='*70}")
        print("✓ COMPARISON COMPLETE!")
        print(f"{'='*70}")
        print(f"Results saved to: {self.run_dir}")
        
        return all_results
    
    def save_results(self):
        """Save results to CSV and JSON"""
        print(f"\n{'='*70}")
        print("SAVING RESULTS")
        print(f"{'='*70}")
        
        if not self.all_results:
            print("⚠️  No results to save")
            return
        
        # Save as CSV
        results_df = pd.DataFrame(self.all_results)
        csv_path = self.results_dir / 'comparison_results.csv'
        results_df.to_csv(csv_path, index=False)
        print(f"✓ Saved CSV: {csv_path}")
        
        # Save as JSON (convert numpy types to native Python types)
        json_path = self.results_dir / 'comparison_results.json'
        
        def convert_to_native(obj):
            """Convert numpy types to native Python types for JSON serialization"""
            if isinstance(obj, dict):
                return {k: convert_to_native(v) for k, v in obj.items()}
            elif isinstance(obj, list):
                return [convert_to_native(item) for item in obj]
            elif isinstance(obj, np.integer):
                return int(obj)
            elif isinstance(obj, np.floating):
                return float(obj)
            elif isinstance(obj, np.ndarray):
                return obj.tolist()
            return obj
        
        results_serializable = convert_to_native(self.all_results)
        
        with open(json_path, 'w') as f:
            json.dump(results_serializable, f, indent=2)
        print(f"✓ Saved JSON: {json_path}")
    
    def create_visualizations(self):
        """Create comparison visualizations"""
        print(f"\n{'='*70}")
        print("CREATING VISUALIZATIONS")
        print(f"{'='*70}")
        
        if not self.all_results:
            print("⚠️  No results to visualize")
            return
        
        results_df = pd.DataFrame(self.all_results)
        
        # Sort by F1 score
        results_df = results_df.sort_values('f1_weighted', ascending=False)
        
        # Create figure
        fig, axes = plt.subplots(2, 2, figsize=(16, 12))
        
        # 1. F1 Score comparison
        ax = axes[0, 0]
        x_pos = np.arange(len(results_df))
        colors = ['#2ecc71' if 'Propagation' in m else '#e74c3c' if 'Forest' in m else '#3498db' 
                  for m in results_df['method']]
        ax.barh(x_pos, results_df['f1_weighted'], color=colors, alpha=0.8, edgecolor='black')
        labels = [f"{row['method']}\n({row['algorithm']})" for _, row in results_df.iterrows()]
        ax.set_yticks(x_pos)
        ax.set_yticklabels(labels, fontsize=9)
        ax.set_xlabel('F1 Score (Weighted)', fontsize=12, fontweight='bold')
        ax.set_title('F1 Score Comparison', fontsize=14, fontweight='bold')
        ax.grid(axis='x', alpha=0.3)
        for i, v in enumerate(results_df['f1_weighted']):
            ax.text(v + 0.005, i, f'{v:.4f}', va='center', fontsize=8)
        
        # 2. Accuracy comparison
        ax = axes[0, 1]
        ax.barh(x_pos, results_df['accuracy'], color=colors, alpha=0.8, edgecolor='black')
        ax.set_yticks(x_pos)
        ax.set_yticklabels(labels, fontsize=9)
        ax.set_xlabel('Accuracy', fontsize=12, fontweight='bold')
        ax.set_title('Accuracy Comparison', fontsize=14, fontweight='bold')
        ax.grid(axis='x', alpha=0.3)
        for i, v in enumerate(results_df['accuracy']):
            ax.text(v + 0.005, i, f'{v:.4f}', va='center', fontsize=8)
        
        # 3. Per-class F1 scores
        ax = axes[1, 0]
        width = 0.35
        ax.barh(x_pos - width/2, results_df['f1_error'], width, 
                label='Error (1)', color='#e74c3c', alpha=0.8, edgecolor='black')
        ax.barh(x_pos + width/2, results_df['f1_correct'], width,
                label='Correct (0)', color='#2ecc71', alpha=0.8, edgecolor='black')
        ax.set_yticks(x_pos)
        ax.set_yticklabels(labels, fontsize=9)
        ax.set_xlabel('F1 Score', fontsize=12, fontweight='bold')
        ax.set_title('Per-Class F1 Scores', fontsize=14, fontweight='bold')
        ax.legend()
        ax.grid(axis='x', alpha=0.3)
        
        # 4. Runtime comparison
        ax = axes[1, 1]
        if 'runtime' in results_df.columns:
            ax.barh(x_pos, results_df['runtime'], color=colors, alpha=0.8, edgecolor='black')
            ax.set_yticks(x_pos)
            ax.set_yticklabels(labels, fontsize=9)
            ax.set_xlabel('Runtime (seconds)', fontsize=12, fontweight='bold')
            ax.set_title('Computational Efficiency', fontsize=14, fontweight='bold')
            ax.grid(axis='x', alpha=0.3)
            for i, v in enumerate(results_df['runtime']):
                ax.text(v + 0.5, i, f'{v:.2f}s', va='center', fontsize=8)
        
        plt.tight_layout()
        plot_path = self.plots_dir / 'method_comparison.png'
        plt.savefig(plot_path, dpi=300, bbox_inches='tight')
        plt.close()
        
        print(f"✓ Saved plot: {plot_path}")
    
    def print_summary(self):
        """Print and save summary"""
        summary_path = self.results_dir / 'summary.txt'
        
        with open(summary_path, 'w') as f:
            def write(text):
                print(text)
                f.write(text + '\n')
            
            write(f"\n{'='*80}")
            write("LABEL PROPAGATION VS RANDOM FOREST - FINAL SUMMARY")
            write(f"{'='*80}")
            
            if not self.all_results:
                write("\n⚠️  No results to summarize")
                return
            
            results_df = pd.DataFrame(self.all_results)
            results_df = results_df.sort_values('f1_weighted', ascending=False)
            
            write("\nRanking by F1 Score:")
            write("-" * 100)
            write(f"{'Method':20s} | {'Algorithm':10s} | {'F1':6s} | {'Accuracy':8s} | "
                  f"{'F1 Error':9s} | {'F1 Correct':10s} | {'Runtime':8s}")
            write("-" * 100)
            
            for _, row in results_df.iterrows():
                write(f"{row['method']:20s} | {row['algorithm']:10s} | "
                      f"{row['f1_weighted']:6.4f} | {row['accuracy']:8.4f} | "
                      f"{row['f1_error']:9.4f} | {row['f1_correct']:10.4f} | "
                      f"{row.get('runtime', 0):8.2f}s")
            
            # Best result
            best = results_df.iloc[0]
            write(f"\n{'='*80}")
            write("🏆 BEST RESULT")
            write(f"{'='*80}")
            write(f"Method: {best['method']}")
            write(f"Algorithm: {best['algorithm']}")
            write(f"F1 Weighted: {best['f1_weighted']:.4f}")
            write(f"Accuracy: {best['accuracy']:.4f}")
            write(f"F1 Error: {best['f1_error']:.4f}")
            write(f"F1 Correct: {best['f1_correct']:.4f}")
            write(f"Runtime: {best.get('runtime', 0):.2f}s")
            
            # Compare methods
            write(f"\n{'='*80}")
            write("METHOD COMPARISON")
            write(f"{'='*80}")
            
            for method in results_df['method'].unique():
                method_results = results_df[results_df['method'] == method]
                avg_f1 = method_results['f1_weighted'].mean()
                avg_acc = method_results['accuracy'].mean()
                write(f"\n{method}:")
                write(f"  Average F1: {avg_f1:.4f}")
                write(f"  Average Accuracy: {avg_acc:.4f}")
                write(f"  Tested on {len(method_results)} clustering algorithms")
        
        print(f"\n✓ Summary saved: {summary_path}")


def main():
    """Main execution"""
    import argparse
    
    parser = argparse.ArgumentParser(
        description='Compare Label Propagation methods vs Random Forest for cell-level error detection'
    )
    
    parser.add_argument(
        '--data-path',
        type=str,
        default=None,
        help='Path to combined_dataset_no_id_v2.csv'
    )
    
    parser.add_argument(
        '--mask-path',
        type=str,
        default=None,
        help='Path to ground_truth_masks_v2.csv'
    )
    
    parser.add_argument(
        '--target-samples',
        type=int,
        default=None,
        help='Number of records to sample (default: 1%% of dataset)'
    )
    
    parser.add_argument(
        '--random-state',
        type=int,
        default=42,
        help='Random seed (default: 42)'
    )
    
    args = parser.parse_args()
    
    # Create comparison instance
    comparison = LabelPropagationComparison(
        target_samples=args.target_samples,
        random_state=args.random_state,
        data_path=args.data_path,
        mask_path=args.mask_path
    )
    
    # Run comparison
    results = comparison.run_comparison()
    
    print(f"\n{'='*70}")
    print("✓ ALL DONE!")
    print(f"{'='*70}")


if __name__ == '__main__':
    main()
